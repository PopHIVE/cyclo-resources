*.Rproj
.Rproj.user
.Rprofile
*.Rprofile
renv/
*.Rhistory
*.Rdata
.DS_Store
.github/pkg.lock

# Quarto/knitr chunk-cache and rendering artifacts - must never be committed,
# since a committed cache makes cached chunks replay stale data forever
# instead of re-executing (this is what broke the scheduled render in CI).
index_cache/
index_files/
/.quarto/

**/*.quarto_ipynb

# OneDrive conflict copies (e.g. "file-MWMJ0G3P8D.ext") created when a synced
# file can't be reconciled across devices
*-MWMJ0G3P8D.*
